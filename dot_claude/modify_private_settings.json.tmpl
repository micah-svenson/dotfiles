#!/bin/sh
# chezmoi modify_ script for ~/.claude/settings.json
#
# chezmoi OWNS the generic skeleton: env, model, hooks, statusLine, spinnerVerbs,
# the assorted flags, and a SEED of the generic official-marketplace plugins.
#
# chezmoi deliberately does NOT own enabledPlugins/extraKnownMarketplaces beyond
# seeding. Those two keys are PRESERVED from the live file so that
# `claude plugin enable/disable` and pac-workspace's `bin/plugin-dev` can toggle
# plugins globally without the next `chezmoi apply` reverting the change.
#
#   - enabledPlugins: base seed + live overlay (live wins per-key).
#   - extraKnownMarketplaces: taken straight from live (base contributes none).
#
# stdin = current ~/.claude/settings.json (empty string on a fresh machine).
set -eu

live="$(cat)"
[ -z "$live" ] && live='{}'

base="$(cat <<'BASE'
{
  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" },
  "model": "opus[1m]",
  "hooks": {
    "Stop": [ { "hooks": [ { "type": "command", "command": "CLAUDE_NOTIFY_SOUND=boing bash {{ .chezmoi.homeDir }}/.claude/scripts/claude-notify/claude-notify.sh", "timeout": 5 } ] } ],
    "Notification": [ { "hooks": [ { "type": "command", "command": "CLAUDE_NOTIFY_SOUND=laser bash {{ .chezmoi.homeDir }}/.claude/scripts/claude-notify/claude-notify.sh", "timeout": 5 } ] } ],
    "SessionStart": [ { "hooks": [ { "type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/tmux_registry.py register", "timeout": 5 } ] } ],
    "SessionEnd": [ { "hooks": [ { "type": "command", "command": "{{ .chezmoi.homeDir }}/.claude/hooks/tmux_registry.py unregister", "timeout": 5 } ] } ]
  },
  "statusLine": { "type": "command", "command": "bash {{ .chezmoi.homeDir }}/.claude/statusline-command.sh" },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": false,
    "ralph-loop@claude-plugins-official": false,
    "playwright@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "jdtls-lsp@claude-plugins-official": false
  },
  "spinnerVerbs": {
    "mode": "replace",
    "verbs": [
      "Échale ganas...",
      "A ver qué sale...",
      "Ándale pues...",
      "Ahorita lo resuelvo...",
      "Chin, déjame pensar...",
      "Órale, vamos...",
      "Chingándole duro...",
      "No hay bronca, espera...",
      "Puro partido...",
      "A huevo que sí...",
      "Sale y vale...",
      "Me estoy rajando...",
      "Trabajando con ganas...",
      "Ay cabrón, ya mero...",
      "Jálale pues...",
      "Con calma, ya viene...",
      "Le estoy buscando...",
      "Ni modo, hay que echarle...",
      "Agarrando el hilo...",
      "Ya casi, no te desesperes...",
      "Chido, procesando...",
      "Aquí andamos...",
      "Híjole, esto sí está grueso...",
      "Al chile, ya mero...",
      "Dándole con todo...",
      "Afinando el tiro...",
      "No te rajes, ya viene...",
      "Puro hueso duro...",
      "Trucha, pensando...",
      "Chamba es chamba..."
    ]
  },
  "alwaysThinkingEnabled": true,
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "voiceEnabled": true
}
BASE
)"

printf '%s' "$base" | jq \
  --argjson live "$live" '
    .enabledPlugins = ((.enabledPlugins // {}) + ($live.enabledPlugins // {}))
    | .extraKnownMarketplaces = ($live.extraKnownMarketplaces // {})
  '
