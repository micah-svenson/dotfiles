# Note: Use `omz reload` to "source" changes to this file.

export LC_ALL=C.utf8
export LANG=C.utf8

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Note: aliases are set in  ~/.oh-my-zsh/custom/aliases.zsh

# See https://github.com/ohmyzsh/ohmyzsh/wiki/Themes
ZSH_THEME="candy" # set by `omz`

# Which plugins would you like to load?
# Standard plugins can be found in $ZSH/plugins/
# Custom plugins may be added to $ZSH_CUSTOM/plugins/
# Example format: plugins=(rails git textmate ruby lighthouse)
# Add wisely, as too many plugins slow down shell startup.
plugins=(git{{ if not .is_work }} notes{{ end }})

# Setup omz.
source $ZSH/oh-my-zsh.sh

# Add ~/.local/bin/ to PATH
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

{{- if and .is_macos (not .is_work) }}
# macOS specific aliases and settings

# PlutoBot — SSH into dedicated bot account
alias pluto='ssh plutobot'
alias pluto-watch='ssh pluto@localhost -t "tmux attach -t claude -r"'

{{- end }}

{{- if .is_linux }}
# Linux specific aliases and settings

# Add tools to PATH
export PATH="$PATH:/opt/nvim-linux-x86_64/bin"
export PATH="$PATH:/home/micah/projects/git-filter-repo"
export PATH="$PATH:/opt/apache-maven-3.9.9/bin"
export PATH="$PATH:/home/micah/.local/share/lua-language-server/bin"
export PATH="$PATH:/usr/local/go/bin"
export PATH="$PATH:/home/micah/.local/share/splunk/splunk/bin"

# Add local bin to PATH if it exists
if [ -d "$HOME/.local/bin" ]; then
    export PATH="$HOME/.local/bin:$PATH"
fi

# Add yarn global bin to PATH
if [ -d "$HOME/.yarn/bin" ]; then
    export PATH="$HOME/.yarn/bin:$PATH"
fi
{{- end }}

## CUSTOM CONFIG ##

{{- if not .is_macos }}
# Persistent SSH agent (systemd user service). macOS provides its own
# ssh-agent via launchd, so SSH_AUTH_SOCK is left untouched there.
export SSH_AUTH_SOCK="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}/ssh-agent.socket"
{{- end }}

# Setup Node Version Manager
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"                   # This loads nvm
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion" # This loads nvm bash_completion


# Setup fzf
if [ -d "$HOME/.fzf/bin" ]; then
  export PATH="$HOME/.fzf/bin:$PATH"
  source <(fzf --zsh)
fi

# GPG TTY for pinentry-curses. Without it, pinentry can't find a
# terminal and hangs on first decrypt after reboot until Ctrl+C.
if [[ -t 0 ]]; then
    export GPG_TTY=$(tty)
fi

{{- if .is_work }}
# On-demand work secrets. Two entry points:
#   unlock-secrets   reads each secret once so the backend prompts/caches
#                    up front. Nothing exported to env.
#   load-secrets     also exports each secret as an env var. Use only
#                    when a child process needs to read them from env
#                    (e.g. opencode reading OPENAI_API_KEY).
#
# Backend: macOS Keychain on Mac, `pass` on Linux/WSL.
#   Add on Linux:  pass insert credentials/<name>
#   Add on Mac:    security add-generic-password -s "credentials/<name>" -a "$USER" -w
# Then append "VAR_NAME=credentials/<name>" to the list below.
_SECRETS=(
    "JIRA_PAT=credentials/jira-pat"
    "OPENAI_API_KEY=credentials/openai-api-key"
    "SONARQUBE_TOKEN=credentials/sonarqube-token"
)

{{- if .is_macos }}
# macOS Keychain backend (service name == the credentials/<name> key)
_secret_get() { security find-generic-password -s "$1" -w 2>/dev/null; }
{{- else }}
# pass / gpg-agent backend
_secret_get() { pass show "$1"; }
{{- end }}

unlock-secrets() {
    local entry key
    for entry in "${_SECRETS[@]}"; do
        key="${entry#*=}"
        _secret_get "$key" >/dev/null || { echo "unlock-secrets: failed on $key" >&2; return 1; }
    done
    echo "unlocked ${#_SECRETS[@]} secrets"
}

load-secrets() {
    local entry var key val
    for entry in "${_SECRETS[@]}"; do
        var="${entry%%=*}"
        key="${entry#*=}"
        val=$(_secret_get "$key") || { echo "load-secrets: failed to read $key" >&2; return 1; }
        export "$var=$val"
        echo "exported $var"
    done
}
{{- end }}

# Machine-local extras (uncommitted). Sourced last so it can override.
[ -f "$HOME/.secrets" ] && source "$HOME/.secrets"

# Language options
export NODE_OPTIONS="--max-old-space-size=4096"
export CLAUDE_CODE_NO_FLICKER=1

# bun
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"
