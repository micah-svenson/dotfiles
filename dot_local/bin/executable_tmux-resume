#!/usr/bin/env python3
"""Recreate tmux sessions and resume their Claude conversations after a reboot.

Reads ~/.claude/tmux-session-registry.json, rebuilds one tmux session per
recorded name (main-window Claude only), runs `claude --resume <id>`, attaches,
then compacts the registry to the restored + still-live set.

Usage: tmux-resume [--dry-run] [session-name-to-attach]
"""
from __future__ import annotations

import fcntl
import glob
import json
import os
import subprocess
import sys

HOME = os.path.expanduser("~")
REGISTRY_PATH = os.path.join(HOME, ".claude", "tmux-session-registry.json")
PROJECTS_DIR = os.path.join(HOME, ".claude", "projects")
LAUNCH_CMD = "claude"  # override here if you launch Claude via a wrapper


def load(path: str) -> dict:
    try:
        with open(path) as f:
            data = json.load(f)
        return data if isinstance(data, dict) else {}
    except (FileNotFoundError, json.JSONDecodeError, ValueError):
        return {}


def atomic_write(path: str, data: dict) -> None:
    tmp = f"{path}.tmp.{os.getpid()}"
    with open(tmp, "w") as f:
        json.dump(data, f, indent=2, sort_keys=True)
        f.write("\n")
    os.replace(tmp, path)


class locked:
    """Exclusive cross-process lock held on a sidecar lockfile."""

    def __init__(self, path: str):
        self._lockpath = f"{path}.lock"
        self._fh = None

    def __enter__(self):
        self._fh = open(self._lockpath, "w")
        fcntl.flock(self._fh, fcntl.LOCK_EX)
        return self

    def __exit__(self, *exc):
        fcntl.flock(self._fh, fcntl.LOCK_UN)
        self._fh.close()


def dedup(reg: dict) -> list:
    """One row per tmux_name: lowest window_index wins, tie-break newest updated_at.
    Returns a list of dicts, each merging session_id with the row fields."""
    best = {}
    for sid, row in reg.items():
        name = row.get("tmux_name")
        if not name:
            continue
        cand = {"session_id": sid, **row}
        cur = best.get(name)
        if cur is None:
            best[name] = cand
            continue
        cur_key = (cur.get("window_index", 1_000_000), cur.get("updated_at", ""))
        new_key = (cand.get("window_index", 1_000_000), cand.get("updated_at", ""))
        if new_key[0] < cur_key[0] or (new_key[0] == cur_key[0] and new_key[1] > cur_key[1]):
            best[name] = cand
    return sorted(best.values(), key=lambda r: r["tmux_name"])


def transcript_exists(session_id: str, projects_dir: str = PROJECTS_DIR) -> bool:
    return bool(glob.glob(os.path.join(projects_dir, "*", f"{session_id}.jsonl")))


def plan_restore(reg: dict, live: set, projects_dir: str = PROJECTS_DIR):
    actions, skipped = [], []
    for row in dedup(reg):
        name = row["tmux_name"]
        if name in live:
            skipped.append((name, "already live"))
        elif not transcript_exists(row["session_id"], projects_dir):
            skipped.append((name, "transcript missing"))
        else:
            actions.append(row)
    return actions, skipped


def commands_for(action: dict, launch_cmd: str = LAUNCH_CMD) -> list:
    name, cwd, sid = action["tmux_name"], action["cwd"], action["session_id"]
    return [
        ["tmux", "new-session", "-d", "-s", name, "-c", cwd],
        ["tmux", "send-keys", "-t", name, f"{launch_cmd} --resume {sid}", "Enter"],
    ]


def compact(reg: dict, kept_session_ids: set) -> dict:
    return {sid: row for sid, row in reg.items() if sid in kept_session_ids}


def live_sessions() -> set:
    try:
        out = subprocess.run(["tmux", "list-sessions", "-F", "#{session_name}"],
                             capture_output=True, text=True, check=True).stdout
        # One name per line; split on lines (not whitespace) so names with
        # spaces survive.
        return {line for line in out.splitlines() if line}
    except subprocess.CalledProcessError:
        return set()  # no tmux server running yet


def main(argv: list[str]) -> int:
    dry = "--dry-run" in argv
    positionals = [a for a in argv[1:] if not a.startswith("-")]
    attach_arg = positionals[0] if positionals else None

    reg = load(REGISTRY_PATH)
    if not reg:
        print("registry empty; nothing to restore", file=sys.stderr)
        return 0

    live_before = live_sessions()
    actions, skipped = plan_restore(reg, live_before)
    for name, reason in skipped:
        print(f"skip {name}: {reason}", file=sys.stderr)

    restored = []
    for action in actions:
        if dry:
            for cmd in commands_for(action):
                print(" ".join(cmd))
            continue
        # One failed restore must not abort the rest.
        try:
            for cmd in commands_for(action):
                subprocess.run(cmd, check=True)
        except subprocess.CalledProcessError as e:
            print(f"failed to restore {action['tmux_name']}: {e}", file=sys.stderr)
            continue
        restored.append(action)
        print(f"restored {action['tmux_name']} -> claude --resume {action['session_id']}",
              file=sys.stderr)

    if dry:
        return 0

    # Compact the registry: keep rows we just restored + rows for sessions that
    # were already live. Re-load under lock so concurrent SessionStart upserts
    # from the resumed Claudes are preserved. (keep_live_ids is computed from the
    # pre-restore snapshot; a session that runs /clear or /compact mid-restore
    # gets a new UUID that is dropped here but re-added by its next SessionStart,
    # so no conversation is lost.)
    restored_ids = {a["session_id"] for a in restored}
    keep_live_ids = {sid for sid, row in reg.items()
                     if row.get("tmux_name") in live_before}
    kept = restored_ids | keep_live_ids
    with locked(REGISTRY_PATH):
        atomic_write(REGISTRY_PATH, compact(load(REGISTRY_PATH), kept))

    # Auto-attach: prefer a just-restored session, else fall back to an existing
    # one (announced, so a no-op restore isn't a silent jump).
    target = attach_arg
    if target is None:
        if restored:
            target = restored[0]["tmux_name"]
        elif live_before:
            target = sorted(live_before)[0]
            print(f"no sessions restored; attaching to existing session {target}",
                  file=sys.stderr)
    if target:
        if os.environ.get("TMUX"):
            subprocess.run(["tmux", "switch-client", "-t", target])
        else:
            os.execvp("tmux", ["tmux", "attach", "-t", target])
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
