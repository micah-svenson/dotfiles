#!/usr/bin/env bash
# Fuzzy-find tmux sessions or create a new one.
# Lists existing sessions; type a custom name to create a new session.
# Works from inside or outside tmux.

result=$(
    tmux list-sessions -F "#{session_name}" 2>/dev/null |
    fzf --prompt="tmux > " \
        --header="select session / type name to create new" \
        --print-query --reverse --height=40%
)

query=$(echo "$result" | sed -n '1p')
match=$(echo "$result" | sed -n '2p')

[ -z "$query" ] && [ -z "$match" ] && exit 0

if [ -n "$match" ]; then
    session_name="$match"
else
    session_name="$query"
fi

# Sanitize session name (tmux doesn't allow dots or colons)
session_name=$(echo "$session_name" | tr './:' '___')

if ! tmux has-session -t="$session_name" 2>/dev/null; then
    tmux new-session -d -s "$session_name"
fi

if [ -z "$TMUX" ]; then
    tmux attach-session -t "$session_name"
else
    tmux switch-client -t "$session_name"
fi
